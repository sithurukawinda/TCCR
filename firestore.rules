rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() { return request.auth != null; }

    // V1 scalar claim — works for admin, super_admin, student
    function hasRole(role) { return isAuthenticated() && request.auth.token.role == role; }

    // V2 check — covers both scalar `role` and `roles[]` array claims
    // Required for leader / g12 which only appear in the roles array
    function hasRoleV2(role) {
      return isAuthenticated() && (
        request.auth.token.role == role ||
        (request.auth.token.roles != null && role in request.auth.token.roles)
      );
    }

    function isAdmin()      { return hasRole('admin') || hasRole('super_admin'); }
    function isSuperAdmin() { return hasRole('super_admin'); }
    function isOwner(uid)   { return isAuthenticated() && request.auth.uid == uid; }

    // leader, g12, admin, super_admin — used for analytics access
    function isLeaderOrAbove() {
      return hasRoleV2('leader') || hasRoleV2('g12') || isAdmin();
    }

    // ── Audit ─────────────────────────────────────────────────────────────────
    match /audit_log/{entry} {
      allow read:   if isSuperAdmin();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // ── Internal / sensitive — no client access ───────────────────────────────
    match /outbox/{entry}            { allow read, write: if false; }
    match /loginAttempts/{email}     { allow read, write: if false; }
    match /passwordResetOtps/{email} { allow read, write: if false; }

    // ── Users ─────────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read:  if isOwner(uid) || isAdmin();
      allow write: if false;
    }

    // ── Courses & content ────────────────────────────────────────────────────
    match /courses/{courseId} {
      allow read:  if (resource.data.state == 'published' && resource.data.deletedAt == null) || isAdmin();
      allow write: if false;
    }

    match /semesters/{semesterId}   { allow read: if isAdmin();         allow write: if false; }
    match /subjects/{subjectId}     { allow read: if isAuthenticated(); allow write: if false; }
    match /lessons/{lessonId}       { allow read: if isAuthenticated(); allow write: if false; }
    match /attachments/{attachId}   { allow read: if isAuthenticated(); allow write: if false; }
    match /batches/{batchId}        { allow read: if isAuthenticated(); allow write: if false; }

    // ── Enrollment ────────────────────────────────────────────────────────────
    match /registrations/{registrationId} { allow read: if isAdmin(); allow write: if false; }

    match /enrollments/{enrollmentId} {
      allow read:  if isOwner(resource.data.studentUid) || isAdmin();
      allow write: if false;
    }

    match /role_requests/{requestId} {
      allow read:  if isOwner(resource.data.requesterUid) || isAdmin();
      allow write: if false;
    }

    // ── Progress ──────────────────────────────────────────────────────────────
    match /progress/{progressId} {
      allow read:  if isOwner(resource.data.studentUid) || isAdmin();
      allow write: if false;
    }

    // ── Notifications ─────────────────────────────────────────────────────────
    match /notifications/{notificationId} {
      allow read:  if isOwner(resource.data.userUid);
      allow write: if false;
    }

    // ── Cell Groups (V2) ──────────────────────────────────────────────────────
    // All active cells are visible to authenticated users; the backend enforces
    // fine-grained scoping (leader→own, member→all active, admin→all).
    match /cell_groups/{cellId} {
      allow read:  if isAuthenticated();
      allow write: if false;

      // Join requests — admin visibility only (leader access enforced by backend)
      match /join_requests/{requestId} {
        allow read:  if isAdmin();
        allow write: if false;
      }

      // Cell reports — visible to authenticated members; backend enforces cell membership
      match /cell_reports/{reportId} {
        allow read:  if isAuthenticated();
        allow write: if false;
      }
    }

    // ── Analytics (V2) ────────────────────────────────────────────────────────
    match /analytics_snapshots/{snapshotId} {
      allow read:  if isLeaderOrAbove();
      allow write: if false;
    }

    // ── Default deny ─────────────────────────────────────────────────────────
    match /{document=**} { allow read, write: if false; }
  }
}
