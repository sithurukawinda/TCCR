{
  "name": "@slp/gateway",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "dotenv -e ../../.env.local -- ts-node-dev --cache-directory .ts-node-cache --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "type-check": "tsc --noEmit",
    "test": "jest --config ../../jest.config.ts --passWithNoTests"
  },
  "dependencies": {
    "@shared/health": "*",
    "@shared/logger": "*",
    "cors": "^2.8.5",
    "express": "^4.18.0",
    "express-rate-limit": "^7.0.0",
    "helmet": "^7.0.0",
    "http-proxy-middleware": "^3.0.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0",
    "dotenv": "^16.0.0"
  }
}
