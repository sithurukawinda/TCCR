{
  "name": "@slp/notification-service",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "dotenv -e ../../.env.local -- ts-node-dev --cache-directory .ts-node-cache --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "type-check": "tsc --noEmit",
    "test": "jest --config ../../jest.config.ts --passWithNoTests"
  },
  "dependencies": {
    "@sendgrid/mail": "^8.0.0",
    "@shared/auth-middleware": "*",
    "@shared/errors": "*",
    "@shared/firebase": "*",
    "@shared/health": "*",
    "@shared/internal-http-client": "*",
    "@shared/logger": "*",
    "@shared/response": "*",
    "express": "^4.18.0",
    "firebase-admin": "^12.0.0",
    "helmet": "^7.0.0",
    "nodemailer": "^8.0.7",
    "uuid": "^9.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/uuid": "^9.0.0",
    "dotenv": "^16.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0"
  }
