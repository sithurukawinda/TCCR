{
  "name": "@slp/scheduled-jobs",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "dotenv -e ../../.env.local -- ts-node-dev --cache-directory .ts-node-cache --respawn --transpile-only src/worker.ts",
    "build": "tsc",
    "start": "node dist/worker.js",
    "type-check": "tsc --noEmit",
    "test": "jest --config ../../jest.config.ts --passWithNoTests"
  },
  "dependencies": {
    "@shared/events": "*",
    "@shared/firebase": "*",
    "@shared/logger": "*",
    "firebase-admin": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0",
    "dotenv": "^16.0.0"
  }
}
