# Copy this file to .env and fill in your values
# .env is gitignored — never commit real credentials

# ── Service Identity ──────────────────────────────────────────────
SERVICE_NAME=course-service
SERVICE_VERSION=1.0.0
NODE_ENV=development
PORT=3003
LOG_LEVEL=info

# ── Firebase Admin SDK ────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
# Required by user-service to verify current password on /me/change-password
FIREBASE_WEB_API_KEY=your-firebase-web-api-key

# ── Internal Service URLs ─────────────────────────────────────────
SERVICE_AUTH_URL=http://localhost:3001
SERVICE_USER_URL=http://localhost:3002
SERVICE_COURSE_URL=http://localhost:3003
SERVICE_ENROLLMENT_URL=http://localhost:3004
SERVICE_PROGRESS_URL=http://localhost:3005
SERVICE_STORAGE_URL=http://localhost:3006
SERVICE_NOTIFICATION_URL=http://localhost:3007
SERVICE_AUDIT_URL=http://localhost:3008

# ── Internal Service Auth ─────────────────────────────────────────
INTERNAL_SERVICE_KEY=change-this-to-a-strong-random-secret

# ── Email (SendGrid — notification-service) ───────────────────────
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=SG.xxxx
EMAIL_FROM=noreply@yourdomain.com

# ── Email (SMTP — auth-service OTP delivery) ──────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-smtp-user@gmail.com
SMTP_PASS=your-smtp-app-password

# ── Gateway ───────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://yourdomain.com,http://localhost:3000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=10

# ── Application URL — login page link in all welcome emails ───────
# Used by auth-service (member registration) and user-service (leader/g12/admin welcome emails)
APP_URL=https://cms.bethelnet.au/login

\
# ── Storage ───────────────────────────────────────────────────────
ATTACHMENT_MAX_SIZE_BYTES=26214400

# ── Outbox Worker ─────────────────────────────────────────────────
OUTBOX_POLL_INTERVAL_SECONDS=5
OUTBOX_BATCH_SIZE=20

# ── Enrollment Rules ──────────────────────────────────────────────
ENROLLMENT_REJECTION_COOLOFF_HOURS=24

# ── Tracing ───────────────────────────────────────────────────────
OTEL_SERVICE_NAME=${SERVICE_NAME}
